# This is an example PKGBUILD file. Use this as a start to creating your own,
# and remove these comments. For more information, see 'man PKGBUILD'.
# NOTE: Please fill out the license field for your package! If it is unknown,
# then please put 'unknown'.

# Maintainer: Mr Chainman <mrchainman@chainman.xyz>
pkgname=chainos-systemd-user-services-git
pkgver="git"
pkgrel=1
epoch=
pkgdesc="Systemd User Serivices for ChainOS"
depends=("systemd")
arch=("x86_64")
url="git+https://github.com/mrchainman/${pkgname%-git}.git"
install=INSTALL
license=("GPL")
source=("$url")
cksums=(SKIP)

package() {
	mkdir -p $pkgdir/${pkgname}/usr/lib/systemd/user
	install -m 644 $srcdir/${pkgname%-git}/* $pkgdir/${pkgname}/usr/lib/systemd/user/
}
